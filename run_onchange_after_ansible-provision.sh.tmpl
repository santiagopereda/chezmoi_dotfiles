#!/bin/bash
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
#
# Run Ansible playbook when provisioner files change.
# chezmoi detects changes via the sha256sum hashes below.
set -euo pipefail

# -- Change detection hashes (chezmoi re-runs this script when any hash changes) --
# group_vars: {{ include ".provisioner/group_vars/all.yml" | sha256sum }}
# local.yml: {{ include ".provisioner/local.yml" | sha256sum }}
# ansible.cfg: {{ include ".provisioner/ansible.cfg" | sha256sum }}
# common/main: {{ include ".provisioner/roles/common/tasks/main.yml" | sha256sum }}
# common/packages-darwin: {{ include ".provisioner/roles/common/tasks/packages-darwin.yml" | sha256sum }}
# common/packages-debian: {{ include ".provisioner/roles/common/tasks/packages-debian.yml" | sha256sum }}
# common/tools-linux: {{ include ".provisioner/roles/common/tasks/tools-linux.yml" | sha256sum }}
# security/main: {{ include ".provisioner/roles/security/tasks/main.yml" | sha256sum }}
# security/ssh: {{ include ".provisioner/roles/security/tasks/ssh.yml" | sha256sum }}
# security/fail2ban: {{ include ".provisioner/roles/security/tasks/fail2ban.yml" | sha256sum }}
# security/firewall: {{ include ".provisioner/roles/security/tasks/firewall.yml" | sha256sum }}
# docker/main: {{ include ".provisioner/roles/docker/tasks/main.yml" | sha256sum }}
# docker/docker-darwin: {{ include ".provisioner/roles/docker/tasks/docker-darwin.yml" | sha256sum }}
# docker/docker-debian: {{ include ".provisioner/roles/docker/tasks/docker-debian.yml" | sha256sum }}
# shell/main: {{ include ".provisioner/roles/shell/tasks/main.yml" | sha256sum }}
# shell/zsh: {{ include ".provisioner/roles/shell/tasks/zsh.yml" | sha256sum }}
# python/main: {{ include ".provisioner/roles/python/tasks/main.yml" | sha256sum }}
# python/uv: {{ include ".provisioner/roles/python/tasks/uv.yml" | sha256sum }}
# python/python-versions: {{ include ".provisioner/roles/python/tasks/python-versions.yml" | sha256sum }}
# node/main: {{ include ".provisioner/roles/node/tasks/main.yml" | sha256sum }}
# node/fnm: {{ include ".provisioner/roles/node/tasks/fnm.yml" | sha256sum }}
# node/node-versions: {{ include ".provisioner/roles/node/tasks/node-versions.yml" | sha256sum }}
# apps/main: {{ include ".provisioner/roles/apps/tasks/main.yml" | sha256sum }}
# apps/apps-darwin: {{ include ".provisioner/roles/apps/tasks/apps-darwin.yml" | sha256sum }}
# apps/apps-debian: {{ include ".provisioner/roles/apps/tasks/apps-debian.yml" | sha256sum }}
# apps/apt-apps-debian: {{ include ".provisioner/roles/apps/tasks/apt-apps-debian.yml" | sha256sum }}
# apps/repos-debian: {{ include ".provisioner/roles/apps/tasks/repos-debian.yml" | sha256sum }}
# apps/snap-apps-debian: {{ include ".provisioner/roles/apps/tasks/snap-apps-debian.yml" | sha256sum }}
# apps/obsidian-debian: {{ include ".provisioner/roles/apps/tasks/obsidian-debian.yml" | sha256sum }}
# apps/terminals-darwin: {{ include ".provisioner/roles/apps/tasks/terminals-darwin.yml" | sha256sum }}
# apps/terminals-debian: {{ include ".provisioner/roles/apps/tasks/terminals-debian.yml" | sha256sum }}
# fonts/main: {{ include ".provisioner/roles/fonts/tasks/main.yml" | sha256sum }}
# fonts/fonts-darwin: {{ include ".provisioner/roles/fonts/tasks/fonts-darwin.yml" | sha256sum }}
# fonts/fonts-linux: {{ include ".provisioner/roles/fonts/tasks/fonts-linux.yml" | sha256sum }}
#
# -- Defaults --
# common/defaults: {{ include ".provisioner/roles/common/defaults/main.yml" | sha256sum }}
# security/defaults: {{ include ".provisioner/roles/security/defaults/main.yml" | sha256sum }}
# docker/defaults: {{ include ".provisioner/roles/docker/defaults/main.yml" | sha256sum }}
# shell/defaults: {{ include ".provisioner/roles/shell/defaults/main.yml" | sha256sum }}
# python/defaults: {{ include ".provisioner/roles/python/defaults/main.yml" | sha256sum }}
# node/defaults: {{ include ".provisioner/roles/node/defaults/main.yml" | sha256sum }}
# apps/defaults: {{ include ".provisioner/roles/apps/defaults/main.yml" | sha256sum }}
# fonts/defaults: {{ include ".provisioner/roles/fonts/defaults/main.yml" | sha256sum }}
#
# -- Handlers --
# docker/handlers: {{ include ".provisioner/roles/docker/handlers/main.yml" | sha256sum }}
# security/handlers: {{ include ".provisioner/roles/security/handlers/main.yml" | sha256sum }}
# fonts/handlers: {{ include ".provisioner/roles/fonts/handlers/main.yml" | sha256sum }}
#
# -- Templates --
# security/sshd_config: {{ include ".provisioner/roles/security/templates/sshd_config.j2" | sha256sum }}
# security/jail.local: {{ include ".provisioner/roles/security/templates/jail.local.j2" | sha256sum }}

CHEZMOI_SOURCE="{{ .chezmoi.sourceDir }}"
PROVISIONER_DIR="$CHEZMOI_SOURCE/.provisioner"

echo "==> Running Ansible provisioner..."

export PATH="$HOME/.local/bin:$PATH"
mkdir -p "$HOME/.local/state/chezmoi"

ANSIBLE_CONFIG="$PROVISIONER_DIR/ansible.cfg" \
  ansible-playbook "$PROVISIONER_DIR/local.yml" \
  --diff

echo "==> Ansible provisioning complete."

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.config/zsh/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Theme
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins
plugins=(git sudo web-search copypath copyfile copybuffer dirhistory history jsontools zsh-autosuggestions F-Sy-H)

# Tell oh-my-zsh where to store the completion dump
ZSH_COMPDUMP="$XDG_CACHE_HOME/zsh/zcompdump-$ZSH_VERSION"

source $ZSH/oh-my-zsh.sh

# Custom web search engines
ZSH_WEB_SEARCH_ENGINES=(stacko "https://stackoverflow.com/search?q=" reddit "https://www.reddit.com/search/?q=" duck "https://duckduckgo.com/?q=")

# History
HISTFILE="$ZDOTDIR/.zhistory"
HISTSIZE=10000
SAVEHIST=10000
REPORTTIME=3
setopt INC_APPEND_HISTORY
setopt EXTENDED_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_SPACE
setopt CORRECT

# Completion style
zstyle ':completion:*' completer _complete _correct _approximate

# rbw SSH agent
if [[ "$OSTYPE" == darwin* ]]; then
  export SSH_AUTH_SOCK="${TMPDIR}rbw-$(id -u)/ssh-agent-socket"
else
  export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/rbw/ssh-agent-socket"
fi

# direnv
command -v direnv &>/dev/null && eval "$(direnv hook zsh)"

# fnm (Node.js version manager)
command -v fnm &>/dev/null && eval "$(fnm env --use-on-cd --shell zsh)"

# uv
command -v uv &>/dev/null && eval "$(uv generate-shell-completion zsh)"

# pip: require virtual environment for global installs
gpip(){
  PIP_REQUIRE_VIRTUALENV="0" python -m pip "$@"
}

# Powerlevel10k config
[[ ! -f ~/.config/zsh/.p10k.zsh ]] || source ~/.config/zsh/.p10k.zsh
